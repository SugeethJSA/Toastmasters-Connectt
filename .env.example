# MongoDB Connection String (required for persistence)
# Get yours from MongoDB Atlas: https://www.mongodb.com/atlas
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/toastmasters?retryWrites=true&w=majority"

# JWT Secret for authentication tokens (change in production!)
JWT_SECRET="toastmasters-connect-secret-key-change-in-production"

# Gemini API Key (optional - for AI features like MOM generation)
GEMINI_API_KEY=""

# Port for the server (default: 3000)
PORT=3000

# For GitHub Pages deployment, the API URL of your Render/Railway backend
# Leave empty if same origin (API served alongside frontend)
VITE_API_URL=""

# Node environment
NODE_ENV="development"